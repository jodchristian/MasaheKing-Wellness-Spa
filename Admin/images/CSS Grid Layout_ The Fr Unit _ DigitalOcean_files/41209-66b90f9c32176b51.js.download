  width: 100%;
  max-width: calc(50rem + 170px + 17rem + 176px);
}

#${o}.inline {
  bottom: 16px;
  margin: 0 auto;
  position: fixed;
  width: 50rem;
}

${(0,S.U)(S.f.tablet)} {
  #${o}.inline {
    width: 50%;
  }

   #${o}.inline .terminal-controls {
    padding: 24px 32px;
  }

  #${o}.inline .terminal-controls ul {
    flex-wrap: wrap-reverse;
    justify-content: end;
    width: 100px;
  }

  #${o} .terminal-controls ul li.separator {
    display: none;
  }
}

#${o} .terminal-controls {
  align-items: center;
  min-height: 38px;
  border: 1px solid ${C.Ay.gray7};
  border-radius: 16px 16px 0 0;
  background-color: ${C.Ay.gray4};
  display: flex;
  padding: 0 32px;
  z-index: 1;
}

${(0,S.U)(S.f.largePhone)} {
  #${o}.inline {
    width: calc(100% - 24px);
  }

  #${o} .terminal-controls {
    padding: 24px 32px;
  }

  #${o} .terminal-controls ul {
    flex-wrap: wrap-reverse;
    justify-content: end;
    width: 100px;
  }

  #${o} .terminal-controls ul li.separator,
  #${o} .terminal-controls ul li.expand,
  #${o} .terminal-controls ul li.shrink {
    display: none;
  }
}

#${o} .terminal-controls-header {
  align-items: center;
  display: flex;
  font-weight: 600;
  font-size: 14px;
  line-height: 22px;
  min-width: 150px;
  color: ${C.Ay.gray6};
}

#${o} .terminal-controls ul {
  display: flex;
  height: 100%;
  margin: 0;
  margin-left: auto;
  padding: 0;
}

#${o} .terminal-controls ul li {
  align-items: center;
  color: ${C.Ay.white};
  cursor: pointer;
  display: flex;
  font-size: 14px;
  font-weight: 600;
  list-style: none;
  margin: .25rem .5rem;
  padding: 0;
}

#${o} .terminal-controls ul li.separator {
  cursor: default;
}

#${o} .terminal-controls ul li svg {
  width: 16px;
  height: 16px;
}

#${o} iframe {
  border: 1px solid ${C.Ay.gray7};
  border-radius: 0 0 16px 16px;
  display: block;
  height: 250px;
  margin: 0 2rem 0 0;
  width: 100%;
}

#${o}.minimized iframe {
  display: none;
}

#${o}.minimized .terminal-controls {
  border-radius: 16px;
}
